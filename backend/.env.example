PORT=5000
MONGODB_URI=mongodb://localhost:27017/cassanova
JWT_SECRET=your-secret-key-change-in-production
NODE_ENV=development

# Coinbase Commerce (crypto payment gateway — US-friendly)
COINBASE_COMMERCE_API_KEY=your-coinbase-commerce-api-key
COINBASE_COMMERCE_WEBHOOK_SECRET=your-webhook-shared-secret

# SMTP (email service — works with any provider: Gmail, SendGrid, Resend, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=Cassanova <noreply@cassanova.com>

# URLs (used for payment redirect callbacks and email links)
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
