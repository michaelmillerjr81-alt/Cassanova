PORT=5000
MONGODB_URI=mongodb://localhost:27017/cassanova
JWT_SECRET=your-secret-key-change-in-production
NODE_ENV=development

# CoinGate (crypto payment gateway)
COINGATE_API_KEY=your-coingate-api-key
COINGATE_ENV=sandbox
COINGATE_CALLBACK_TOKEN=your-random-callback-secret

# SMTP (email service — works with any provider: Gmail, SendGrid, Resend, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=Cassanova <noreply@cassanova.com>

# URLs (used for CoinGate redirect callbacks and email links)
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
